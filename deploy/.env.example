# ─── Supabase ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Stripe (LIVE keys) ─────────────────────────────────────
# Live keys are already configured in Replit secrets.
# Copy them to your server's .env — do NOT use test keys in production.
STRIPE_SECRET_KEY=sk_live_...
# Get this from Stripe Dashboard → Developers → Webhooks
# Register a NEW webhook for each server pointing to:
#   https://yourdomain.com/api/webhooks/stripe
# Each environment (dev, beta, prod) needs its own webhook + secret.
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ────────────────────────────────────────────────────
# Your server's public URL — controls Stripe post-payment redirects
APP_ORIGIN=https://yourdomain.com

# ─── Server ─────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=production
